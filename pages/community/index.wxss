/* pages/community/index.wxss */
.page { min-height: 100vh; background: #f5f7fa; }
.page-header { background: #fff; padding: calc(env(safe-area-inset-top) + 40rpx) 32rpx 32rpx; border-bottom: 1px solid #f0f0f0; }
.page-title { font-size: 40rpx; font-weight: 700; display: block; }
.page-sub { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }
.post-list { padding: 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.post-card { background: #fff; border-radius: 20rpx; padding: 28rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.post-author-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 20rpx; }
.avatar-sm { width: 72rpx; height: 72rpx; border-radius: 50%; background: linear-gradient(135deg,#07c160,#10b981); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 28rpx; font-weight: 700; flex-shrink: 0; }
.author-name { font-size: 28rpx; font-weight: 600; display: block; }
.post-meta { font-size: 22rpx; color: #999; }
.post-content { font-size: 30rpx; line-height: 1.7; color: #1a1a1a; display: block; margin-bottom: 20rpx; }
.post-actions { display: flex; gap: 32rpx; }
.action-btn { display: flex; align-items: center; gap: 8rpx; font-size: 26rpx; color: #999; }
.action-btn.liked { color: #dc2626; }
.empty-state { text-align: center; padding: 100rpx; display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.empty-icon { font-size: 80rpx; }
.empty-title { font-size: 32rpx; font-weight: 600; }
.empty-sub { font-size: 26rpx; color: #999; }
.fab { position: fixed; bottom: 160rpx; right: 40rpx; width: 100rpx; height: 100rpx; background: #07c160; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 24rpx rgba(7,193,96,0.35); z-index: 100; }
.fab-icon { font-size: 60rpx; color: #fff; font-weight: 300; }
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 200; display: flex; align-items: flex-end; }
.modal-box { background: #fff; border-radius: 32rpx 32rpx 0 0; width: 100%; padding: 32rpx; box-sizing: border-box; }
.modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.modal-title { font-size: 34rpx; font-weight: 700; }
.modal-close { font-size: 32rpx; color: #999; }
.input-field { width: 100%; padding: 20rpx 24rpx; background: #f5f5f5; border-radius: 16rpx; font-size: 28rpx; margin-bottom: 16rpx; border: none; box-sizing: border-box; }
.textarea-field { width: 100%; min-height: 200rpx; padding: 24rpx; background: #f9f9f9; border-radius: 16rpx; font-size: 30rpx; line-height: 1.7; border: none; box-sizing: border-box; resize: none; }
.btn-submit { width: 100%; background: #07c160; color: #fff; border-radius: 20rpx; padding: 28rpx; font-size: 32rpx; font-weight: 600; border: none; margin-top: 20rpx; }
