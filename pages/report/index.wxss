/* pages/report/index.wxss */
.page { min-height: 100vh; background: #f5f7fa; }

/* Header */
.report-header { padding: calc(env(safe-area-inset-top) + 48rpx) 32rpx 56rpx; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.report-date { font-size: 24rpx; color: rgba(0,0,0,0.4); }
.report-emoji { font-size: 96rpx; line-height: 1; }
.report-level { font-size: 40rpx; font-weight: 700; margin-top: 8rpx; }
.report-tip { font-size: 26rpx; color: rgba(0,0,0,0.55); max-width: 560rpx; line-height: 1.6; }

/* Score */
.score-section { background: #fff; padding: 40rpx 32rpx; display: flex; flex-direction: column; align-items: center; gap: 24rpx; }
.score-ring { width: 200rpx; height: 200rpx; border-radius: 50%; border: 12rpx solid currentColor; display: flex; align-items: center; justify-content: center; }
.score-ring-inner { display: flex; align-items: baseline; gap: 4rpx; }
.score-big { font-size: 64rpx; font-weight: 800; }
.score-total { font-size: 28rpx; color: #999; }
.score-bar-full { width: 100%; max-width: 600rpx; height: 16rpx; background: #f0f0f0; border-radius: 999rpx; overflow: hidden; }
.score-bar-fill { height: 100%; border-radius: 999rpx; transition: width 0.8s ease; }

/* Sections */
.section { padding: 32rpx; }
.section-title { font-size: 32rpx; font-weight: 700; color: #1a1a1a; margin-bottom: 20rpx; display: block; }
.cat-card { border-radius: 16rpx; padding: 24rpx 28rpx; margin-bottom: 16rpx; }
.cat-header { display: flex; align-items: center; gap: 12rpx; }
.cat-emoji { font-size: 32rpx; }
.cat-name { font-size: 28rpx; font-weight: 600; flex: 1; }
.cat-count { font-size: 28rpx; font-weight: 700; }
.cat-bar-bg { flex: 1; height: 8rpx; background: rgba(0,0,0,0.08); border-radius: 999rpx; overflow: hidden; }
.cat-bar-fill { height: 100%; border-radius: 999rpx; }

/* Strategy */
.strategy-item { display: flex; align-items: flex-start; gap: 16rpx; padding: 20rpx 24rpx; background: #fff; border-radius: 16rpx; margin-bottom: 12rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.strategy-icon { font-size: 28rpx; flex-shrink: 0; margin-top: 2rpx; }
.strategy-text { font-size: 28rpx; color: #333; line-height: 1.6; flex: 1; }

/* Actions */
.action-section { padding: 32rpx 32rpx calc(env(safe-area-inset-bottom) + 32rpx); display: flex; flex-direction: column; gap: 16rpx; }

/* Buttons */
.btn-full { width: 100%; padding: 28rpx; border-radius: 20rpx; font-size: 32rpx; font-weight: 600; border: none; }
.btn-brand { background: #07c160; color: #fff; }
.btn-outline { background: transparent; border: 3rpx solid #07c160; color: #07c160; }
.btn-ghost { background: #f5f5f5; color: #666; }
.mt-2 { margin-top: 16rpx; }

/* Color */
.text-red-600 { color: #dc2626; }
.text-orange-600 { color: #ea580c; }
.text-yellow-600 { color: #ca8a04; }
.text-green-600 { color: #16a34a; }
