<view class="page">
  <view class="profile-header">
    <view class="profile-avatar">{{profile.industry ? profile.industry[0] : '?'}}</view>
    <view class="profile-info">
      <text class="profile-name">{{profile.industry || '未设置'}} · {{profile.workYears || '未填写'}}</text>
      <text class="profile-sub">A里味用户</text>
    </view>
    <button class="btn-edit" bindtap="openEdit">编辑</button>
  </view>

  <!-- Stats -->
  <view class="stats-grid">
    <view class="stat-item">
      <text class="stat-num">{{testHistory.length}}</text>
      <text class="stat-label">测试次数</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{diaries.length}}</text>
      <text class="stat-label">日记篇数</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{practiceCount}}</text>
      <text class="stat-label">练习次数</text>
    </view>
  </view>

  <!-- Menu -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goTestHistory">
      <text>📊 测试历史</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="clearData">
      <text>🗑 清除本地数据</text>
      <text class="menu-arrow">→</text>
    </view>
  </view>

  <!-- Edit Modal -->
  <view wx:if="{{showEdit}}" class="modal-mask" bindtap="closeEdit">
    <view class="modal-box" catchtap="noop">
      <view class="modal-header">
        <text class="modal-title">编辑个人资料</text>
        <text class="modal-close" bindtap="closeEdit">✕</text>
      </view>
      <view class="form-group">
        <text class="form-label">行业</text>
        <picker mode="selector" range="{{industries}}" bindchange="onIndustryChange">
          <view class="picker-value">{{editIndustry || '请选择行业'}}</view>
        </picker>
      </view>
      <view class="form-group">
        <text class="form-label">工作年限</text>
        <picker mode="selector" range="{{workYearsOptions}}" bindchange="onWorkYearsChange">
          <view class="picker-value">{{editWorkYears || '请选择'}}</view>
        </picker>
      </view>
      <button class="btn-save" bindtap="saveProfile">保存</button>
    </view>
  </view>
</view>
