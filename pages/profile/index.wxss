/* pages/profile/index.wxss */
.page { min-height: 100vh; background: #f5f7fa; }
.profile-header { background: linear-gradient(135deg,#07c160,#10b981); padding: calc(env(safe-area-inset-top) + 40rpx) 32rpx 56rpx; display: flex; align-items: center; gap: 24rpx; }
.profile-avatar { width: 120rpx; height: 120rpx; border-radius: 50%; background: rgba(255,255,255,0.3); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 48rpx; font-weight: 700; flex-shrink: 0; }
.profile-info { flex: 1; color: #fff; }
.profile-name { font-size: 36rpx; font-weight: 700; display: block; margin-bottom: 8rpx; }
.profile-sub { font-size: 26rpx; opacity: 0.8; }
.btn-edit { background: rgba(255,255,255,0.2); border: 2rpx solid rgba(255,255,255,0.5); color: #fff; border-radius: 16rpx; padding: 16rpx 28rpx; font-size: 26rpx; }
.stats-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1px; background: #e5e5e5; margin: 24rpx; border-radius: 20rpx; overflow: hidden; }
.stat-item { background: #fff; padding: 32rpx 16rpx; text-align: center; }
.stat-num { font-size: 48rpx; font-weight: 800; color: #07c160; display: block; }
.stat-label { font-size: 22rpx; color: #999; margin-top: 8rpx; display: block; }
.menu-list { margin: 0 24rpx; background: #fff; border-radius: 20rpx; overflow: hidden; }
.menu-item { display: flex; align-items: center; justify-content: space-between; padding: 32rpx; font-size: 30rpx; border-bottom: 1px solid #f0f0f0; }
.menu-item:last-child { border-bottom: none; }
.menu-arrow { color: #ccc; }
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 200; display: flex; align-items: center; justify-content: center; }
.modal-box { background: #fff; border-radius: 32rpx; width: 90%; max-width: 600rpx; padding: 40rpx; }
.modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32rpx; }
.modal-title { font-size: 34rpx; font-weight: 700; }
.modal-close { color: #999; font-size: 32rpx; }
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #666; display: block; margin-bottom: 12rpx; }
.picker-value { padding: 20rpx 24rpx; background: #f5f5f5; border-radius: 16rpx; font-size: 28rpx; }
.btn-save { width: 100%; background: #07c160; color: #fff; border-radius: 20rpx; padding: 28rpx; font-size: 32rpx; font-weight: 600; border: none; margin-top: 16rpx; }
